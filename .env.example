# NASA Earthdata authentication for ASF/Sentinel-1 downloads.
# Copy this file to .env and fill in your own values locally.
# Register/manage account and user tokens at: https://urs.earthdata.nasa.gov/
# Do not commit .env, paste real values into chat/logs, or add them to tests.

# Preferred: Earthdata bearer token/user token. Paste only the token value.
# A leading "Bearer " prefix is tolerated by the code but is not required.
EARTHDATA_TOKEN=

# Optional alias if your local tooling already uses this name.
# EARTHDATA_BEARER_TOKEN=

# Legacy fallback: username/password remains supported when no token is set.
EARTHDATA_USERNAME=
EARTHDATA_PASSWORD=
